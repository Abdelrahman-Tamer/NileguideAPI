{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NileGuideApi",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build NileGuideApi",
      "program": "${workspaceFolder}/NileGuideApi/bin/Debug/net8.0/NileGuideApi.dll",
      "args": [],
      "cwd": "${workspaceFolder}/NileGuideApi",
      "stopAtEntry": false,
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/swagger"
      },
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7069;http://localhost:5126"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}/Views"
      }
    }
  ]
}
